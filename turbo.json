{
  "$schema": "https://v2-8-0.turborepo.dev/schema.json",
  "ui": "tui",
  "globalDependencies": [".env*"],
  "globalEnv": [
    "DATABASE_URL",
    "GOOGLE_CLIENT_ID",
    "GOOGLE_CLIENT_SECRET",
    "NEXT_PUBLIC_API_URL",
    "BETTER_AUTH_SECRET",
    "BETTER_AUTH_URL",
    "NEXT_PUBLIC_APP_URL",
    "R2_ACCOUNT_ID",
    "R2_ACCESS_KEY_ID",
    "R2_SECRET_ACCESS_KEY",
    "R2_BUCKET",
    "R2_PUBLIC_BASE_URL",
    "RESEND_API_KEY",
    "AUTH_COOKIE_DOMAIN",
    "AUTH_TRUSTED_ORIGINS",
    "GITHUB_CLIENT_ID",
    "GITHUB_CLIENT_SECRET",
    "GITHUB_APP_ID",
    "GITHUB_APP_PRIVATE_KEY",
    "GITHUB_APP_INSTALL_URL",
    "GITHUB_APP_SLUG",
    "GITHUB_WEBHOOK_SECRET",
    "GITHUB_SETUP_STATE_SECRET",
    "UPSTASH_REDIS_REST_URL",
    "UPSTASH_REDIS_REST_TOKEN",
    "RATE_LIMIT_ENABLED",
    "API_RATE_LIMIT_ENABLED",
    "AUTH_RATE_LIMIT_ENABLED",
    "MARBLE_API_URL",
    "MARBLE_WORKSPACE_KEY",
    "SENTRY_AUTH_TOKEN",
    "PASSKEY_RP_ID",
    "PASSKEY_RP_NAME",
    "PASSKEY_ORIGIN",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "STRIPE_PRICE_ID_STARTER_MONTHLY",
    "STRIPE_PRICE_ID_STARTER_YEARLY",
    "STRIPE_PRICE_ID_PROFESSIONAL_MONTHLY",
    "STRIPE_PRICE_ID_PROFESSIONAL_YEARLY",
    "API_TRUSTED_ORIGINS",
    "FLAGS",
    "FLAGS_SECRET",
    "NOTRA_CREDENTIALS_ENCRYPTION_KEY",
    "NOTRA_CREDENTIALS_ENCRYPTION_ACTIVE_VERSION",
    "VISITORS_TOKEN",
    "NEXT_PUBLIC_SELINE_TOKEN"
  ],
  "tasks": {
    "transit": {
      "dependsOn": ["^transit"]
    },
    "build": {
      "dependsOn": ["^build", "^check-types", "check-types"],
      "inputs": ["$TURBO_DEFAULT$"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "lint": {
      "dependsOn": ["transit"]
    },
    "check-types": {
      "dependsOn": ["transit"]
    },
    "test": {
      "dependsOn": ["transit"],
      "inputs": ["$TURBO_DEFAULT$", ".env.test", "docker-compose.test.yml"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    }
  }
}
