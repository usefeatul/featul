# Marble CMS configuration
# Copy to `.env.local` and fill in your workspace key
MARBLE_API_URL=https://api.marblecms.com/v1
MARBLE_WORKSPACE_KEY=your_workspace_key_here
NEXT_PUBLIC_DASHBOARD_URL=https://app.featul.com
NEXT_PUBLIC_LIVE_DEMO_URL=https://featul.com
# Site URL used for canonical links, OG URLs, robots, and sitemap
NEXT_PUBLIC_SITE_URL=https://featul.com
# Hosted c15t backend URL used by the local /api/c15t proxy route
# Prefer C15T_URL on the server, keep NEXT_PUBLIC_C15T_URL so the marketing consent UI knows to render
C15T_URL=https://your-project.consent.io
NEXT_PUBLIC_C15T_URL=https://your-project.consent.io
# Optional: Google Search Console verification token
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=your_google_site_verification_token_here
# Visitors analytics token for the marketing site root layout
VISITORS_TOKEN=your_visitors_token_here
# Optional: Seline analytics token for the marketing site root layout
NEXT_PUBLIC_SELINE_TOKEN=your_seline_token_here
