NEXT_PUBLIC_APP_URL=https://app.featul.com
NEXT_PUBLIC_POSTHOG_TOKEN=replace_with_posthog_project_token
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com
AUTH_COOKIE_DOMAIN=featul.com
AUTH_TRUSTED_ORIGINS=https://featul.com,https://app.featul.com,https://*.featul.com
BETTER_AUTH_SECRET=replace_with_secure_random
SENTRY_AUTH_TOKEN=replace_with_secure_random
UPSTASH_REDIS_REST_URL=replace_with_secure_random
UPSTASH_REDIS_REST_TOKEN=replace_with_secure_random
OPENROUTER_API_KEY=replace_with_openrouter_key
OPENROUTER_MODEL=openrouter/auto
OPENROUTER_APP_NAME=Featul
OPENROUTER_REFERER=https://app.featul.com

# GitHub App integration (issue sync)
GITHUB_APP_ID=replace_with_github_app_id
GITHUB_APP_PRIVATE_KEY=replace_with_github_app_private_key_pem
# Set one of the following:
GITHUB_APP_SLUG=replace_with_github_app_slug
# GITHUB_APP_INSTALL_URL=https://github.com/apps/your-app-slug/installations/new
GITHUB_WEBHOOK_SECRET=replace_with_github_webhook_secret
GITHUB_SETUP_STATE_SECRET=replace_with_long_random_secret

# Notra credential encryption
NOTRA_CREDENTIALS_ENCRYPTION_KEY=replace_with_long_random_secret

# Passkeys
PASSKEY_RP_ID=localhost
PASSKEY_RP_NAME=Featul
PASSKEY_ORIGIN=http://localhost:3000

# Stripe billing
STRIPE_SECRET_KEY=replace_with_stripe_secret_key
STRIPE_WEBHOOK_SECRET=replace_with_stripe_webhook_secret
STRIPE_PRICE_ID_STARTER_MONTHLY=replace_with_stripe_starter_monthly_price_id
STRIPE_PRICE_ID_STARTER_YEARLY=replace_with_stripe_starter_yearly_price_id
STRIPE_PRICE_ID_PROFESSIONAL_MONTHLY=replace_with_stripe_professional_monthly_price_id
STRIPE_PRICE_ID_PROFESSIONAL_YEARLY=replace_with_stripe_professional_yearly_price_id
